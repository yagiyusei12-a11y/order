# ---------------------------------------------------------------------------
# Docker の Postgres と Prisma 共通
# ---------------------------------------------------------------------------
# POSTGRES_PASSWORD … docker-compose.yml の Postgres が参照する。
# DATABASE_URL       … Prisma / アプリが参照する。パスワード部分は POSTGRES_PASSWORD と同じ文字列にすること。
#
# 例（ローカル開発・compose デフォルトと揃える場合）:
#   POSTGRES_PASSWORD=order_local_dev
#   DATABASE_URL="postgresql://order:order_local_dev@localhost:5432/order?schema=public"
#
# 本番（VPS）では POSTGRES_PASSWORD を長いランダムな英数字に変更し、DATABASE_URL のパスワードも同一にする。
# （@ : / ? # などをパスワードに含めると URL のエスケープが必要になるので、最初は英数字のみ推奨）
POSTGRES_PASSWORD=
DATABASE_URL=

# 本番では必須（24文字以上のランダム文字列）
JWT_SECRET=

# スタッフログイン Cookie / JWT の有効期間（既定 400d ≈ 端末にログインしっぱなし）
# JWT_EXPIRES_IN=400d
# Cookie maxAge（秒）を JWT と別にしたいときだけ指定
# JWT_COOKIE_MAX_AGE_SECONDS=

# リバースプロキシ（nginx / Caddy 等）の後ろで動かすとき X-Forwarded-* を信頼する
# 本番でプロキシ経由なら 1
TRUST_PROXY=0

# HTTPS で配信する場合は 1（httpOnly Cookie の Secure に必要）。本番で TLS 終端なら 1
COOKIE_SECURE=0

# 直接 Node で TLS 終端するとき（どちらか一方だけでは不可）
HTTPS_KEY_PATH=
HTTPS_CERT_PATH=

# ログイン試行レート制限（1分あたり）
AUTH_LOGIN_MAX_PER_MINUTE=30

# 1 にすると /staff-app/setup と POST /auth/bootstrap を無効化（本番で初回登録を閉じるとき）
BOOTSTRAP_DISABLED=0

# ---------------------------------------------------------------------------
# メール送信（任意・未設定なら送信しない）
# テイクアウト注文確定・ネット予約確定（メール入力時）などで利用。
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
# TLS を最初から張る場合は 465 + SMTP_SECURE=true が一般的
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
# スタッフ「設定」で店舗 SMTP を有効にしている場合は上記は不要（店舗優先、未設定時のみここへフォールバック）。

# ---------------------------------------------------------------------------
# 参考: Neon などクラウド DB だけ使う場合
# ---------------------------------------------------------------------------
# DATABASE_URL にホスト付きの接続文字列だけを設定し、docker compose の postgres は使わない運用も可。
