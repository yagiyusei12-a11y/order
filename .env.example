# PostgreSQL 接続文字列（例: postgresql://user:pass@localhost:5432/order?schema=public）
DATABASE_URL=

# --- ローカル DB でレイテンシ比較するとき ------------------------------------
# 1) Docker Desktop を入れたうえでプロジェクト直下で:  docker compose up -d
# 2) 下のどちらか一方だけを .env に設定（Neon の URL はコメントアウトする）
#
# DATABASE_URL="postgresql://order:order_local_dev@localhost:5432/order?schema=public"
#
# 3) 初回またはローカル DB を空にした直後:
#    npm run db:setup
# 4) アプリ: npm run dev   →  http://127.0.0.1:3000/health/db で select1Ms を比較
#
# Neon に戻すときは DATABASE_URL を元の接続文字列に戻すだけ。
# （ローカルにだけあったデータは Neon には乗らない。Neon の複製が必要なら pg_dump / pg_restore を別途）

# 本番では必須（24文字以上のランダム文字列）
JWT_SECRET=

# リバースプロキシ（nginx / Caddy 等）の後ろで動かすとき X-Forwarded-* を信頼する
TRUST_PROXY=0

# HTTPS で配信する場合は 1（httpOnly Cookie の Secure に必要）
COOKIE_SECURE=0

# 直接 Node で TLS 終端するとき（どちらか一方だけでは不可）
HTTPS_KEY_PATH=
HTTPS_CERT_PATH=

# ログイン試行レート制限（1分あたり）
AUTH_LOGIN_MAX_PER_MINUTE=30
