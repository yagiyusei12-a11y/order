{
  "name": "order",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "db:generate": "prisma generate",
    "db:migrate": "prisma db push",
    "db:deploy": "prisma db push",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "import:menu-csv": "tsx prisma/import-menu-csv.ts",
    "seed:harunoyukoto-tables": "tsx prisma/seed-harunoyukoto-tables.ts",
    "seed:harunoyukoto-games": "tsx prisma/seed-harunoyukoto-games.ts",
    "seed:harunoyukoto-games:upsert": "tsx prisma/upsert-harunoyukoto-games.ts",
    "seed:buzzer-quiz:harunoyukoto": "tsx prisma/seed-buzzer-quiz-harunoyukoto.ts",
    "dump:store-games": "tsx prisma/dump-store-games.ts",
    "lock:store-games": "tsx prisma/lock-store-games.ts",
    "restore:store-games": "tsx prisma/restore-store-games-snapshot.ts",
    "import:harunoyukoto-menu": "tsx prisma/import-menu-csv.ts prisma/data/harunoyukoto-nagahama-menu.csv harunoyukoto",
    "import:harunoyukoto-sales": "tsx prisma/import-harunoyukoto-transactions-csv.ts",
    "delete:harunoyukoto-import-bills": "tsx prisma/delete-harunoyukoto-import-bills.ts",
    "delete:harunoyukoto-import-bills:vps": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/delete-harunoyukoto-import-bills-vps.ps1",
    "delete:harunoyukoto-import-bills:vps:execute": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/delete-harunoyukoto-import-bills-vps.ps1 -Execute",
    "debug:harunoyukoto-report": "tsx prisma/report-debug-harunoyukoto.ts",
    "db:setup": "prisma generate && prisma db push",
    "db:local:up": "docker compose up -d",
    "db:local:down": "docker compose down",
    "vps:bootstrap": "bash deploy/vps/bootstrap.sh",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:dev": "npm run db:setup && npm run dev",
    "first-run": "npm install && npm run db:setup && npm run dev",
    "deploy:vps": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/deploy-vps.ps1",
    "deploy:vps:daiko": "powershell -NoProfile -ExecutionPolicy Bypass -File ../daiko/scripts/deploy-vps.ps1",
    "import:harunoyukoto-sales:vps": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/import-harunoyukoto-sales-vps.ps1",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.0.4",
    "@fastify/multipart": "^9.3.0",
    "@fastify/rate-limit": "^10.2.2",
    "@prisma/client": "^6.6.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.0.0",
    "bcryptjs": "^3.0.2",
    "fastify": "^5.2.2",
    "nodemailer": "^8.0.7",
    "prisma": "^6.6.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.19.3"
  }
}
