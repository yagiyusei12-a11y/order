generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 店舗
model Store {
  id               String               @id @default(cuid())
  name             String
  /// 店舗オプション（キッチン更新間隔・ゲスト表示など JSON）
  settings         Json                 @default("{}")
  staffUsers       StaffUser[]
  methods          StorePaymentMethod[]
  bills            Bill[]
  tables           Table[]
  courses          Course[]
  menuCategories   MenuCategory[]
  optionGroups     OptionGroup[]
  kitchenStations  KitchenStation[]
  sessions         DiningSession[]
  timeWindows      StoreTimeWindow[]
  customers        Customer[]
  receptionConfig  ReceptionConfig?
  receptionState   ReceptionState?
  receptionShifts  ReceptionShift[]
  receptionReservations ReceptionReservation[]
  createdAt        DateTime             @default(now())
}

/// QR経由の匿名端末会員（店舗スコープ）。端末IDで識別し、名前・電話は任意。
model Customer {
  id         String            @id @default(cuid())
  storeId    String
  deviceId   String
  name       String?
  phone      String?
  visitCount Int               @default(0)
  lastSeenAt DateTime          @default(now())
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  store      Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sessions   DiningSession[]

  @@unique([storeId, deviceId])
  @@index([storeId])
  @@index([storeId, lastSeenAt])
}

/// 店舗の「何時から何時まで」マスタ（カテゴリのゲスト表示時間・商品の時間帯割引で参照）
model StoreTimeWindow {
  id        String   @id @default(cuid())
  storeId   String
  name      String
  /// 店舗 timezone の 0 時からの分（0〜1439）
  startMin  Int
  endMin    Int
  sortOrder Int      @default(0)
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  categoriesGuestVisible MenuCategory[] @relation("GuestVisibleTimeWindow")
  itemDiscounts          MenuItemTimeDiscount[]

  @@index([storeId])
}

/// 商品ごとの時間帯割引（税込販売価格に対して適用。複数該当時は最も安くなる1件）
model MenuItemTimeDiscount {
  id           String          @id @default(cuid())
  menuItemId   String
  timeWindowId String
  /// percent（0〜100）または fixed_yen（税込から減算する円）
  discountKind String
  value        Int
  menuItem     MenuItem        @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  timeWindow   StoreTimeWindow @relation(fields: [timeWindowId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, timeWindowId])
  @@index([menuItemId])
  @@index([timeWindowId])
}

/// 調理場（キッチン絞り込み用。ゲスト画面には出さないマスタ）
model KitchenStation {
  id        String     @id @default(cuid())
  storeId   String
  name      String
  sortOrder Int        @default(0)
  active    Boolean    @default(true)
  store     Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  menuItems MenuItem[]

  @@index([storeId])
}

/// 店舗スタッフ（店舗コンソール・店舗API用）
model StaffUser {
  id           String   @id @default(cuid())
  storeId      String
  email        String
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, email])
  @@index([storeId])
}

/// 決済手段の定義（全店共通マスタ。店ごとに有効/無効・並びを上書き）
model PaymentMethodDefinition {
  id        String               @id @default(cuid())
  code      String               @unique
  labelJa   String
  sortOrder Int                  @default(0)
  stores    StorePaymentMethod[]
}

model StorePaymentMethod {
  id           String                  @id @default(cuid())
  storeId      String
  definitionId String
  enabled      Boolean                 @default(true)
  sortOrder    Int                     @default(0)
  store        Store                   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  definition   PaymentMethodDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@unique([storeId, definitionId])
}

/// 会計（任意で来店セッションに紐づけ）
model Bill {
  id          String    @id @default(cuid())
  storeId     String
  sessionId   String?   @unique
  label       String?
  totalAmount Int
  status      String    @default("open")
  payments    Payment[]
  createdAt   DateTime  @default(now())
  settledAt   DateTime?
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  session     DiningSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
}

model Payment {
  id         String   @id @default(cuid())
  billId     String
  methodCode String
  amount     Int
  note       String?
  createdAt  DateTime @default(now())
  bill       Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
}

/// 卓（固定QRは publicCode で表現可能）
model Table {
  id         String            @id @default(cuid())
  storeId    String
  name       String
  publicCode String            @unique
  sortOrder  Int               @default(0)
  /// 収容人数（ネット予約/受付の席割りに使用）
  capacity   Int               @default(2)
  /// 合体可能な席（publicCode の配列を JSON で保持）
  mergeWith  Json              @default("[]")
  active     Boolean           @default(true)
  store      Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sessions   DiningSession[]

  @@index([storeId])
}

/// 食べ放題・飲み放題・食べ飲み放題コース（料金・制限時間は CoursePriceTier で複数パターン可能）
model Course {
  id          String            @id @default(cuid())
  storeId     String
  name        String
  kind        String
  active      Boolean           @default(true)
  store       Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sessions    DiningSession[]
  includedItems CourseMenuItem[]
  priceTiers  CoursePriceTier[]
  optionPacks CourseOptionPack[]

  @@index([storeId])
}

/// コースに上乗せする「＋オプション」。卓が購入すると紐づく単品がコース対象に追加される。
model CourseOptionPack {
  id         String   @id @default(cuid())
  courseId   String
  name       String
  /// table_once=卓1回定額, per_person_pick=一人あたり×お客指定人数, per_person_all=一人あたり×延べ人数
  chargeScope String  @default("table_once")
  /// 円・整数。table_once=卓1回。per_person_*=一人あたり（税込/税抜は extraPriceTaxMode）
  extraPrice Int
  /// inclusive=税込入力, exclusive=税抜入力（会計行は店舗税率で税込に換算）
  extraPriceTaxMode String @default("inclusive")
  sortOrder  Int      @default(0)
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  menuItems  CourseOptionPackMenuItem[]

  @@index([courseId])
}

model CourseOptionPackMenuItem {
  packId     String
  menuItemId String
  pack       CourseOptionPack @relation(fields: [packId], references: [id], onDelete: Cascade)
  menuItem   MenuItem         @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@id([packId, menuItemId])
  @@index([menuItemId])
}

/// コースの時間（分）・単価パターン（例: 60分・90分で金額を分ける）
model CoursePriceTier {
  id                  String          @id @default(cuid())
  courseId            String
  durationMinutes     Int
  pricePerPerson      Int
  childPricePerPerson Int?
  sortOrder           Int             @default(0)
  course              Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  sessions            DiningSession[]

  @@unique([courseId, durationMinutes])
  @@index([courseId])
}

/// コースで注文可能なメニュー商品（未設定のコースは店舗メニュー全品）
model CourseMenuItem {
  courseId   String
  menuItemId String
  /// 延べ人数がこの値以上のとき、この商品をコース対象（単品本体0円）に含める。1=全人数で対象。
  minGuestCount Int      @default(1)
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@id([courseId, menuItemId])
  @@index([menuItemId])
}

model MenuCategory {
  id               String     @id @default(cuid())
  storeId          String
  parentId         String?
  name             String
  sortOrder        Int        @default(0)
  /// false のカテゴリはゲストメニューに出さない（厨房・スタッフ用）
  visibleToGuest   Boolean    @default(true)
  /// ゲスト向け表示の開始（店舗設定の timezone の 0 時からの経過分・0〜1439）。guestVisibleEndMin と両方 null なら時間制限なし
  guestVisibleStartMin Int?
  /// ゲスト向け表示の終了（同上）。開始より大きい場合は翌日跨ぎ（例 22:00〜02:00）
  guestVisibleEndMin   Int?
  /// 設定時はマスタの時間帯でゲスト表示を判定（guestVisibleStartMin/EndMin は無視）
  guestVisibleTimeWindowId String?
  guestVisibleTimeWindow   StoreTimeWindow? @relation("GuestVisibleTimeWindow", fields: [guestVisibleTimeWindowId], references: [id], onDelete: SetNull)
  store            Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  parent           MenuCategory? @relation("MenuCategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children         MenuCategory[] @relation("MenuCategoryHierarchy")
  items            MenuItem[]

  @@index([storeId])
  @@index([parentId])
}

model MenuItem {
  id                String          @id @default(cuid())
  categoryId        String
  name              String
  description       String?
  imageUrl          String?
  price             Int
  /// 価格入力モード: inclusive=税込入力, exclusive=税抜入力（表示は税抜（税込））
  priceTaxMode      String          @default("inclusive")
  /// single=通常商品, set=セット（setSteps で項目・候補を定義）
  sellKind          String          @default("single")
  sortOrder         Int             @default(0)
  isAvailable       Boolean         @default(true)
  /// null = 在庫管理しない（注文で減らない）
  stockQty          Int?
  /// 在庫管理時、残数がこの値以下なら「在庫少」（null ならしきい値アラートなし）
  stockLowThreshold Int?
  kitchenStationId  String?
  /// キッチンまとめ表示の調理タイマー（秒）。null / 0 = 未使用
  cookTimerSec      Int?
  /// 同一商品の2つ目の調理タイマー（秒）。null / 0 = 未使用
  cookTimerSec2     Int?
  /// 酒類（未成年・運転者向けの注文制限の対象。マスタで指定）
  containsAlcohol   Boolean         @default(false)
  /// メニュー保存の楽観ロック（PATCH 時 ifMasterVersion と照合）
  masterVersion     Int             @default(1)
  category          MenuCategory    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  kitchenStation    KitchenStation? @relation(fields: [kitchenStationId], references: [id], onDelete: SetNull)
  orderLines        OrderLine[]
  courseLinks       CourseMenuItem[]
  courseOptionPackItems CourseOptionPackMenuItem[]
  optionLinks       MenuItemOptionGroup[]
  timeDiscounts     MenuItemTimeDiscount[]
  setSteps          MenuSetStep[]   @relation("MenuSetOfItem")
  setChoiceAsComponent MenuSetChoice[] @relation("MenuSetChoiceComponent")

  @@index([categoryId])
  @@index([kitchenStationId])
}

/// セット商品の選択項目（例: 焼き鳥・一品など）
model MenuSetStep {
  id            String          @id @default(cuid())
  setMenuItemId String
  label         String
  /// この項目で選ぶ個数の下限（0 なら任意）
  minPick       Int             @default(1)
  /// この項目で選ぶ個数の上限
  maxPick       Int             @default(1)
  sortOrder     Int             @default(0)
  /// true のときゲストが「後から提供」を選ぶと、この項目が別 OrderLine（0円）になる
  allowServeLaterSplit Boolean  @default(false)
  setMenuItem   MenuItem        @relation("MenuSetOfItem", fields: [setMenuItemId], references: [id], onDelete: Cascade)
  choices       MenuSetChoice[]

  @@index([setMenuItemId])
}

/// セット項目の候補となる単品（extraPrice は税抜の上乗せ円・会計時に店舗税率で税込換算）
model MenuSetChoice {
  id                  String       @id @default(cuid())
  stepId              String
  componentMenuItemId String
  extraPrice          Int          @default(0)
  sortOrder           Int          @default(0)
  /// true のときゲストは選べず常にセットに含める（標準付属）
  isFixed             Boolean      @default(false)
  step                MenuSetStep  @relation(fields: [stepId], references: [id], onDelete: Cascade)
  componentMenuItem   MenuItem     @relation("MenuSetChoiceComponent", fields: [componentMenuItemId], references: [id], onDelete: Cascade)

  @@index([stepId])
  @@index([componentMenuItemId])
}

/// 商品オプショングループ（例: トッピング、サイズ）
model OptionGroup {
  id         String                @id @default(cuid())
  storeId    String
  name       String
  minSelect  Int                   @default(0)
  maxSelect  Int                   @default(1)
  sortOrder  Int                   @default(0)
  active     Boolean               @default(true)
  store      Store                 @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items      OptionItem[]
  menuLinks  MenuItemOptionGroup[]

  @@index([storeId])
}

model OptionItem {
  id          String      @id @default(cuid())
  groupId     String
  name        String
  priceDelta  Int         @default(0)
  sortOrder   Int         @default(0)
  active      Boolean     @default(true)
  group       OptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

/// 商品に紐づくオプショングループ（複数可）
model MenuItemOptionGroup {
  menuItemId    String
  optionGroupId String
  sortOrder     Int         @default(0)
  menuItem      MenuItem    @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  optionGroup   OptionGroup @relation(fields: [optionGroupId], references: [id], onDelete: Cascade)

  @@id([menuItemId, optionGroupId])
  @@index([optionGroupId])
}

/// 1組の滞在（卓・人数・コース・ゲスト用トークン）
model DiningSession {
  id         String       @id @default(cuid())
  storeId    String
  tableId    String
  guestToken String       @unique
  courseId   String?
  /// 選択したコース料金・制限時間パターン
  coursePriceTierId String?
  guestCount Int
  /// 子供の人数（0〜guestCount）。残りは大人としてコース単価を適用。
  childCount Int          @default(0)
  /// ゲストの飲酒確認（null=未送信・酒類注文は不可。true=可、false=不可）
  guestAlcoholAllowed Boolean?
  status     String       @default("open")
  openedAt   DateTime     @default(now())
  closedAt   DateTime?
  customerId String?
  customer   Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  store      Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  table      Table        @relation(fields: [tableId], references: [id], onDelete: Cascade)
  course          Course?          @relation(fields: [courseId], references: [id], onDelete: SetNull)
  coursePriceTier CoursePriceTier? @relation(fields: [coursePriceTierId], references: [id], onDelete: SetNull)
  /// 支払い済みのコース＋オプション（CourseOptionPack.id の JSON 配列）
  purchasedCourseOptionPackIds Json @default("[]")
  orders          SalesOrder[]
  bill       Bill?

  @@index([storeId])
  @@index([tableId])
  @@index([customerId])
}

/// 受付：設定（店舗ごとに1行）
model ReceptionConfig {
  storeId    String @id
  /// { staff: number, override: boolean, manualWait: number } 互換の JSON
  data       Json   @default("{\"staff\":6,\"override\":false,\"manualWait\":30}")
  updatedAt  DateTime @updatedAt
  store      Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

/// 受付：システム状態（店舗ごとに1行）
model ReceptionState {
  storeId     String @id
  callReserved Boolean @default(false)
  callType    String  @default("")
  /// 呼び出し・入店受付のキュー（互換 JSON）
  entryQueue  Json    @default("[]")
  updatedAt   DateTime @updatedAt
  store       Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

/// 受付：日付＋シフト単位の席状態（店舗スコープ）
model ReceptionShift {
  id        String @id @default(cuid())
  storeId   String
  /// 例: 2026-05-06_lunch / 2026-05-06_dinner
  shiftKey  String
  seats     Json   @default("[]")
  waiting   Json   @default("[]")
  updatedAt DateTime @updatedAt
  store     Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, shiftKey])
  @@index([storeId])
}

/// 受付：予約（店舗スコープ）
model ReceptionReservation {
  id        String @id @default(cuid())
  storeId   String
  /// 旧システム互換キー（resId）
  resKey    String
  /// 予約データ JSON（旧システム互換）
  data      Json
  /// 検索用（data から冗長に保持）
  date      String
  shift     String
  status    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, resKey])
  @@index([storeId])
  @@index([storeId, date])
}

/// 受付：予約座席ロック（同一 seatId の二重予約防止）
model ReceptionReservationSeat {
  id       String @id @default(cuid())
  storeId  String
  shiftKey String
  seatId   String
  resKey   String

  @@unique([storeId, shiftKey, seatId])
  @@index([storeId, resKey])
  @@index([storeId, shiftKey])
}

model SalesOrder {
  id        String      @id @default(cuid())
  sessionId String
  status    String      @default("submitted")
  note      String?
  createdAt DateTime    @default(now())
  session   DiningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  lines     OrderLine[]

  @@index([sessionId])
}

model OrderLine {
  id           String     @id @default(cuid())
  orderId      String
  menuItemId   String?
  nameSnapshot String
  unitPrice    Int
  qty          Int
  note         String?
  /// セット注文時の内訳など JSON（kind: set, steps: [...]）
  lineExtra    Json?
  status       String     @default("queued")
  /// キッチンで「調理済」にした日時（提供待ちの並び順用）
  readyAt      DateTime?
  /// ホールで「提供済み」にした日時（提供済み一覧の並び用）
  servedAt     DateTime?
  order        SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem     MenuItem?  @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([status, readyAt])
  @@index([status, servedAt])
}
